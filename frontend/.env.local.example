# 실제 백엔드 연동 (npm run dev)
# Next.js rewrites로 API를 프록시하므로 프론트와 같은 origin을 사용합니다.
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 백엔드 프록시 대상 (next.config.ts, 기본값: http://localhost:8080)
API_PROXY_TARGET=http://localhost:8080

# Mock 모드는 npm run local 사용 시 자동 설정됩니다 (NEXT_PUBLIC_USE_MOCK=true)
